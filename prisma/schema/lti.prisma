model LtiPlatform {
  id           String  @id @default(cuid())
  name         String  // e.g. "Blackboard — ECC"
  issuer       String  // e.g. "https://blackboard.edisonohio.edu"
  clientId     String
  authLoginUrl String  // Platform OIDC login endpoint
  authTokenUrl String  // Platform token endpoint
  keysetUrl    String  // Platform public JWKS URL
  deploymentId String
  isActive     Boolean @default(true)

  // Migrated RSA key pair (PEM-encoded, stored encrypted)
  // kid must match the kid registered with Blackboard during original setup
  privateKeyPem String? @db.Text
  publicKeyPem  String? @db.Text
  keyId         String?

  ltiLaunches LtiLaunch[]
  ltiNonces   LtiNonce[]

  @@unique([issuer, clientId])
  @@map("lti_platforms")
}

model LtiNonce {
  id         String   @id @default(cuid())
  platformId String
  nonce      String
  state      String
  expiresAt  DateTime

  platform LtiPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([platformId, nonce])
  @@map("lti_nonces")
}

model LtiLaunch {
  id             String   @id @default(cuid())
  platformId     String
  userId         String?  // matched local user (null if unrecognised)
  sub            String   // platform-side user identifier
  contextId      String?  // LMS course context
  resourceLinkId String?
  roles          String[] // LTI role URNs
  launchedAt     DateTime @default(now())
  targetUrl      String?
  customParams   Json     @default("{}")

  platform LtiPlatform @relation(fields: [platformId], references: [id])

  @@map("lti_launches")
}

model LtiDeepLink {
  id           String   @id @default(cuid())
  platformId   String
  token        String   @unique // short-lived one-time token
  expiresAt    DateTime
  returnUrl    String   // deep_link_return_url from LMS
  deploymentId String

  @@map("lti_deep_links")
}
