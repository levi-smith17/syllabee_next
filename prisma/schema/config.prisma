// Stores arbitrary key/value system config.
// Sensitive values (e.g. entra_client_secret) are AES-256 encrypted before storage.
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model Branding {
  id              String  @id @default(cuid())
  institutionName String
  primaryColor    String  @default("#0066cc")
  secondaryColor  String  @default("#ffffff")
  logoUrl         String?
  faviconUrl      String?

  @@map("branding")
}

model QuickLink {
  id        String   @id @default(cuid())
  label     String
  url       String
  icon      String?
  restricted Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("quick_links")
}
