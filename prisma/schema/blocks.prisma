// Block is the atomic content unit. Type-specific data lives in:
//   - `data` JSON field (for simple/flat structures: video URL, list style, table rows, course info)
//   - Relational sub-tables (for records with their own lifecycle: schedule, questions, files)
model Block {
  id        String    @id @default(cuid())
  type      BlockType
  title     String?
  isVisible Boolean   @default(true)
  sortHint  Int       @default(0)
  ownerId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Flat/JSON data field — used by: CONTENT, DETAILS, VIDEO, LIST, TABLE, COURSE_SYLLABUS, GRADE_DETERMINATION
  data Json @default("{}")

  owner User?  @relation("OwnedBlocks", fields: [ownerId], references: [id])
  bonds Bond[]

  // Relational sub-tables — used by blocks with multi-record structures
  scheduleUnits   ScheduleUnit[]
  questions       Question[]
  fileAttachments FileAttachment[]
  listItems       ListItem[]
  gradeDetermRows GradeDetermRow[]

  @@map("blocks")
}

// ── SCHEDULE block ────────────────────────────────────────────────────────────

model ScheduleUnit {
  id        String    @id @default(cuid())
  blockId   String
  weekNum   Int
  date      DateTime?
  label     String?
  sortOrder Int       @default(0)

  block  Block           @relation(fields: [blockId], references: [id], onDelete: Cascade)
  topics ScheduleTopic[]

  @@map("schedule_units")
}

model ScheduleTopic {
  id             String  @id @default(cuid())
  scheduleUnitId String
  topic          String
  reading        String?
  sortOrder      Int     @default(0)

  scheduleUnit ScheduleUnit @relation(fields: [scheduleUnitId], references: [id], onDelete: Cascade)

  @@map("schedule_topics")
}

// ── RESPONSE block ────────────────────────────────────────────────────────────

model Question {
  id        String       @id @default(cuid())
  blockId   String
  text      String       @db.Text
  type      QuestionType @default(MULTIPLE_CHOICE)
  sortOrder Int          @default(0)

  block           Block             @relation(fields: [blockId], references: [id], onDelete: Cascade)
  choices         Choice[]
  attemptProgress AttemptProgress[]

  @@map("questions")
}

model Choice {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("choices")
}

// ── GRADE_DETERMINATION block ─────────────────────────────────────────────────
// Stored in `data` JSON as { rows: [{id, category, weight, description}] }
// Also available as relational rows for server-side queries/reporting.
model GradeDetermRow {
  id          String  @id @default(cuid())
  blockId     String
  category    String
  weight      Float
  description String? @db.Text
  sortOrder   Int     @default(0)

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@map("grade_determ_rows")
}

// ── LIST block ────────────────────────────────────────────────────────────────
// Items are also mirrored to the `data` JSON for fast reads.
model ListItem {
  id        String @id @default(cuid())
  blockId   String
  text      String @db.Text
  sortOrder Int    @default(0)

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@map("list_items")
}

// ── FILE block ────────────────────────────────────────────────────────────────

model FileAttachment {
  id         String   @id @default(cuid())
  blockId    String
  fileName   String
  fileKey    String   // Cloudflare R2 object key
  fileSize   Int      // bytes
  mimeType   String
  uploadedAt DateTime @default(now())

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@map("file_attachments")
}
