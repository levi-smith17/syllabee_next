model InternshipSettings {
  id                         String  @id @default(cuid())
  pointsPerHour              Float   @default(1.0)
  minHoursRequired           Float   @default(120)
  maxPointsPerDay            Float   @default(8.0)
  journalRequired            Boolean @default(true)
  supervisorApprovalRequired Boolean @default(false)

  @@map("internship_settings")
}

model InternshipLocation {
  id              String  @id @default(cuid())
  businessName    String
  address         String?
  city            String?
  state           String?
  zip             String?
  supervisorName  String?
  supervisorEmail String?
  supervisorPhone String?

  internships Internship[]

  @@map("internship_locations")
}

model Internship {
  id         String           @id @default(cuid())
  userId     String
  sectionId  String?
  locationId String?
  status     InternshipStatus @default(PENDING)
  totalHours Float            @default(0)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  section  Section?            @relation(fields: [sectionId], references: [id])
  location InternshipLocation? @relation(fields: [locationId], references: [id])

  journalEntries InternshipJournalEntry[]

  @@map("internships")
}

model InternshipJournalEntry {
  id           String   @id @default(cuid())
  internshipId String
  title        String
  description  String   @db.Text
  hoursLogged  Float
  entryDate    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@map("internship_journal_entries")
}
