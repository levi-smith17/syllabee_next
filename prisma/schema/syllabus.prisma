model MasterSyllabus {
  id              String          @id @default(cuid())
  title           String
  termId          String?
  ownerId         String?
  interactionMode InteractionMode @default(INTERACTIVE)
  isPublished     Boolean         @default(false)
  showProgress    Boolean         @default(true)
  allowPrint      Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  term  Term? @relation(fields: [termId], references: [id])
  owner User? @relation("OwnedMasterSyllabi", fields: [ownerId], references: [id])

  masterBonds MasterBond[]

  @@map("master_syllabi")
}

model Segment {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  isVisible   Boolean @default(true)
  ownerId     String?

  owner User? @relation("OwnedSegments", fields: [ownerId], references: [id])

  masterBonds MasterBond[]
  bonds       Bond[]

  @@map("segments")
}

// Junction: MasterSyllabus ↔ Segment (ordered)
model MasterBond {
  id               String @id @default(cuid())
  masterSyllabusId String
  segmentId        String
  sortOrder        Int    @default(0)
  ownerId          String?

  masterSyllabus MasterSyllabus @relation(fields: [masterSyllabusId], references: [id], onDelete: Cascade)
  segment        Segment        @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  owner          User?          @relation("OwnedMasterBonds", fields: [ownerId], references: [id])

  masterBondProgress    MasterBondProgress[]
  masterBondSections    MasterBondSection[]

  @@unique([masterSyllabusId, segmentId])
  @@map("master_bonds")
}

// Junction: MasterBond ↔ Section (which instructor "owns" this bond in which section)
model MasterBondSection {
  id           String @id @default(cuid())
  masterBondId String
  sectionId    String
  ownerId      String

  masterBond MasterBond @relation(fields: [masterBondId], references: [id], onDelete: Cascade)
  section    Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  owner      User       @relation("OwnedMasterBondSections", fields: [ownerId], references: [id])

  @@unique([masterBondId, sectionId])
  @@map("master_bond_sections")
}

// Junction: Segment ↔ Block (ordered)
model Bond {
  id        String @id @default(cuid())
  segmentId String
  blockId   String
  sortOrder Int     @default(0)
  ownerId   String?

  segment Segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  block   Block   @relation(fields: [blockId], references: [id], onDelete: Cascade)
  owner   User?   @relation("OwnedBonds", fields: [ownerId], references: [id])

  bondProgress BondProgress[]

  @@unique([segmentId, blockId])
  @@map("bonds")
}
