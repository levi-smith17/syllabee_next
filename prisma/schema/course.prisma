model Term {
  id                   String      @id @default(cuid())
  name                 String      // e.g. "Fall 2024"
  code                 String      @unique // e.g. "FA24"
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean     @default(true)
  termLengthId         String?
  hasMidpointBreak     Boolean     @default(false)
  supportsMasterSyllabi Boolean    @default(false)

  termLength     TermLength?      @relation(fields: [termLengthId], references: [id])
  sections       Section[]
  masterSyllabi  MasterSyllabus[]

  @@map("terms")
}

model TermLength {
  id                  String  @id @default(cuid())
  label               String  // e.g. "16-week"
  weeks               Int
  canHaveMidpointBreak Boolean @default(false)

  terms Term[]

  @@map("term_lengths")
}

model Course {
  id          String  @id @default(cuid())
  code        String  @unique // e.g. "CS101"
  title       String
  description String? @db.Text
  creditHours Int     @default(3)
  isActive      Boolean @default(true)
  isInternship  Boolean @default(false)

  sections Section[]

  @@map("courses")
}

model Section {
  id                  String   @id @default(cuid())
  courseId            String
  termId              String
  sectionCode         String   // e.g. "001"
  permalink           String?  @unique
  hash                String   @unique @default(cuid()) // /viewer/s/:hash
  instructorId        String?
  roomNumber          String?
  meetingDays         String?
  meetingTime         String?
  formatId            String?
  archivedSyllabusPath String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  course  Course         @relation(fields: [courseId], references: [id])
  term    Term           @relation(fields: [termId], references: [id])
  format  SectionFormat? @relation(fields: [formatId], references: [id])

  sectionProgress    SectionProgress[]
  internships        Internship[]
  masterBondSections MasterBondSection[]

  @@unique([courseId, termId, sectionCode])
  @@map("sections")
}

model SectionFormat {
  id    String @id @default(cuid())
  label String @unique

  sections         Section[]
  sectionCodeRules SectionCodeRule[]

  @@map("section_formats")
}

model SectionCodeRule {
  id       String        @id @default(cuid())
  digit    String        // single char "0"–"9"
  formatId String

  format SectionFormat @relation(fields: [formatId], references: [id])

  @@unique([digit])
  @@map("section_code_rules")
}
