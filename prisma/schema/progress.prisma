// Student progress through a syllabus section

model SectionProgress {
  id          String    @id @default(cuid())
  userId      String
  sectionId   String
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  masterBondProgress MasterBondProgress[]

  @@unique([userId, sectionId])
  @@map("section_progress")
}

model MasterBondProgress {
  id                String    @id @default(cuid())
  sectionProgressId String
  masterBondId      String
  completedAt       DateTime?

  sectionProgress SectionProgress @relation(fields: [sectionProgressId], references: [id], onDelete: Cascade)
  masterBond      MasterBond      @relation(fields: [masterBondId], references: [id], onDelete: Cascade)

  bondProgress BondProgress[]

  @@unique([sectionProgressId, masterBondId])
  @@map("master_bond_progress")
}

model BondProgress {
  id                   String    @id @default(cuid())
  masterBondProgressId String
  bondId               String
  completedAt          DateTime?

  masterBondProgress MasterBondProgress @relation(fields: [masterBondProgressId], references: [id], onDelete: Cascade)
  bond               Bond               @relation(fields: [bondId], references: [id], onDelete: Cascade)

  responseProgress ResponseProgress[]

  @@unique([masterBondProgressId, bondId])
  @@map("bond_progress")
}

model ResponseProgress {
  id             String    @id @default(cuid())
  bondProgressId String
  score          Float?
  maxScore       Float?
  completedAt    DateTime?

  bondProgress    BondProgress    @relation(fields: [bondProgressId], references: [id], onDelete: Cascade)
  attemptProgress AttemptProgress[]

  @@map("response_progress")
}

model AttemptProgress {
  id                 String   @id @default(cuid())
  responseProgressId String
  questionId         String
  selectedChoiceId   String?
  isCorrect          Boolean?
  attemptedAt        DateTime @default(now())

  responseProgress ResponseProgress @relation(fields: [responseProgressId], references: [id], onDelete: Cascade)
  question         Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("attempt_progress")
}
